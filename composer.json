{
    "name": "andreaval/cohesion2-library",
    "description": "Libreria PHP per l'autenticazione al sistema di SSO Cohesion2 della Regione Marche",
    "type": "library",
    "keywords": ["php", "Cohesion2", "Regione Marche", "SSO", "Single Sign-On", "SAML 2.0", "SPID", "eIDAS"],
    "homepage": "https://github.com/andreaval/Cohesion2PHPLibrary",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrea Vallorani",
            "email": "andrea.vallorani@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/andreaval/Cohesion2PHPLibrary/issues",
        "source": "https://github.com/andreaval/Cohesion2PHPLibrary"
    },
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-simplexml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": { "andreaval\\Cohesion2\\": "cohesion2/" }
    },
    "autoload-dev": {
        "psr-4": { "andreaval\\Cohesion2\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --no-progress"
    }
}
